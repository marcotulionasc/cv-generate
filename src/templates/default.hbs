<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{nome}} - Currículo</title>
  <!-- Apenas hex/rgb simples (sem lab/oklch/rgba) para html2canvas/PDF -->
  <style>
    * { box-sizing: border-box; color: #1e293b; }
    body { margin: 0; font-family: Arial, Helvetica, sans-serif; background: #f8fafc; color: #1e293b; }
    .cv-article { max-width: 56rem; margin: 2rem auto; background: #ffffff; box-shadow: 0 10px 30px #d1d5db; border-radius: 0.5rem; overflow: hidden; }
    .cv-header { background: #0f172a; background-color: #0f172a; color: #fff; padding: 2.5rem 2rem; }
    .cv-header h1 { font-size: 1.875rem; font-weight: 700; letter-spacing: -0.025em; margin: 0; color: #ffffff; }
    .cv-header .subtitle { color: #cbd5e1; font-size: 1.125rem; margin-top: 0.25rem; }
    .cv-header .links { display: flex; flex-wrap: wrap; gap: 0.25rem 1.5rem; margin-top: 1.5rem; font-size: 0.875rem; color: #cbd5e1; }
    .cv-header .links a { color: #cbd5e1; text-decoration: none; }
    .cv-header .links a:hover { color: #fff; }
    .cv-header .links span { color: #cbd5e1; }
    .cv-body { padding: 2rem; }
    .cv-body > * + * { margin-top: 2rem; }
    .cv-section h2 { font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin: 0 0 1rem 0; }
    .cv-section p { color: #334155; line-height: 1.625; margin: 0; }
    .cv-section .space-y-6 > * + * { margin-top: 1.5rem; }
    .cv-section .space-y-4 > * + * { margin-top: 1rem; }
    .cv-section .space-y-3 > * + * { margin-top: 0.75rem; }
    .cv-section .space-y-2 > * + * { margin-top: 0.5rem; }
    .cv-section .space-y-1 > * + * { margin-top: 0.25rem; }
    .cv-job { border-left: 2px solid #e2e8f0; padding-left: 1.25rem; }
    .cv-job .row { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
    .cv-job h3 { font-weight: 600; color: #0f172a; margin: 0; }
    .cv-job .period { font-size: 0.875rem; color: #64748b; }
    .cv-job .company { color: #475569; font-weight: 500; margin-top: 0.25rem; }
    .cv-job .desc { color: #334155; margin-top: 0.5rem; font-size: 0.875rem; }
    .cv-job ul { margin: 0.5rem 0 0 0; padding-left: 1rem; font-size: 0.875rem; color: #334155; list-style: disc inside; }
    .cv-edu h3 { font-weight: 600; color: #0f172a; margin: 0; }
    .cv-edu .meta { color: #475569; font-size: 0.875rem; margin-top: 0.25rem; }
    .cv-skills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .cv-skill { display: inline-block; padding: 0.25rem 0.75rem; background: #f1f5f9; color: #334155; border-radius: 9999px; font-size: 0.875rem; }
    .cv-skill-sm { padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.875rem; }
    .cv-list { color: #334155; list-style: none; padding: 0; margin: 0; }
    .cv-list li { margin-top: 0.25rem; }
    .cv-list li:first-child { margin-top: 0; }
    .cv-link { font-weight: 600; color: #0f172a; text-decoration: none; }
    .cv-link:hover { color: #475569; }
    .cv-cat { font-size: 0.875rem; font-weight: 500; color: #475569; margin-bottom: 0.25rem; }
  </style>
</head>
<body>
  <article class="cv-article">
    {{!-- Header com nome e contato --}}
    <header class="cv-header" style="background-color:#0f172a;color:#fff">
      <h1>{{nome}}</h1>
      {{#if titulo}}
        <p class="subtitle">{{titulo}}</p>
      {{/if}}
      <div class="links">
        <a href="mailto:{{email}}">{{email}}</a>
        {{#if telefone}}<span>{{telefone}}</span>{{/if}}
        {{#if localizacao}}<span>{{localizacao}}</span>{{/if}}
        {{#if linkedin}}<a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
        {{#if github}}<a href="https://{{github}}" target="_blank" rel="noopener">GitHub</a>{{/if}}
        {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">Website</a>{{/if}}
      </div>
    </header>

    <div class="cv-body">
      {{!-- Resumo --}}
      {{#if resumo}}
        <section class="cv-section">
          <h2>Resumo</h2>
          <p>{{resumo}}</p>
        </section>
      {{/if}}

      {{!-- Experiência --}}
      {{#if experiencias}}
        <section class="cv-section">
          <h2>Experiência profissional</h2>
          <div class="space-y-6">
            {{#each experiencias}}
              <div class="cv-job">
                <div class="row">
                  <h3>{{cargo}}</h3>
                  <span class="period">{{periodo}}</span>
                </div>
                <p class="company">{{empresa}}{{#if local}} · {{local}}{{/if}}</p>
                {{#if descricao}}
                  <p class="desc">{{descricao}}</p>
                {{/if}}
                {{#if conquistas}}
                  <ul>
                    {{#each conquistas}}
                      <li>{{this}}</li>
                    {{/each}}
                  </ul>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{!-- Formação --}}
      {{#if formacao}}
        <section class="cv-section">
          <h2>Formação</h2>
          <div class="space-y-4">
            {{#each formacao}}
              <div class="cv-edu">
                <h3>{{curso}}</h3>
                <p class="meta">{{instituicao}} · {{periodo}}</p>
                {{#if descricao}}<p class="desc">{{descricao}}</p>{{/if}}
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{!-- Habilidades (lista simples) --}}
      {{#if habilidadesLista}}
        <section class="cv-section">
          <h2>Habilidades</h2>
          <div class="cv-skills">
            {{#each habilidadesLista}}
              <span class="cv-skill">{{this}}</span>
            {{/each}}
          </div>
        </section>
      {{/if}}
      {{!-- Habilidades por categoria --}}
      {{#if habilidadesCategorias}}
        <section class="cv-section">
          <h2>Habilidades</h2>
          <div class="space-y-3">
            {{#each habilidadesCategorias}}
              <div>
                <p class="cv-cat">{{categoria}}</p>
                <div class="cv-skills">
                  {{#each itens}}
                    <span class="cv-skill cv-skill-sm">{{this}}</span>
                  {{/each}}
                </div>
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{!-- Idiomas --}}
      {{#if idiomas}}
        <section class="cv-section">
          <h2>Idiomas</h2>
          <ul class="cv-list">
            {{#each idiomas}}
              <li><span style="font-weight:600">{{idioma}}</span> — {{nivel}}</li>
            {{/each}}
          </ul>
        </section>
      {{/if}}

      {{!-- Projetos --}}
      {{#if projetos}}
        <section class="cv-section">
          <h2>Projetos</h2>
          <div class="space-y-4">
            {{#each projetos}}
              <div>
                {{#if link}}
                  <a href="{{link}}" target="_blank" rel="noopener" class="cv-link">{{nome}}</a>
                {{else}}
                  <h3 style="font-weight:600;color:#0f172a;margin:0">{{nome}}</h3>
                {{/if}}
                {{#if descricao}}<p class="desc">{{descricao}}</p>{{/if}}
                {{#if tecnologias}}
                  <div class="cv-skills" style="margin-top:0.5rem">
                    {{#each tecnologias}}
                      <span class="cv-skill cv-skill-sm">{{this}}</span>
                    {{/each}}
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{!-- Certificações --}}
      {{#if certificacoes}}
        <section class="cv-section">
          <h2>Certificações</h2>
          <ul class="cv-list" style="margin-top:0.5rem">
            {{#each certificacoes}}
              <li>
                {{#if link}}<a href="{{link}}" target="_blank" rel="noopener" style="text-decoration:underline">{{nome}}</a>{{else}}{{nome}}{{/if}}
                {{#if emissor}} · {{emissor}}{{/if}}{{#if ano}} ({{ano}}){{/if}}
              </li>
            {{/each}}
          </ul>
        </section>
      {{/if}}
    </div>
  </article>
</body>
</html>
