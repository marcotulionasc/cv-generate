<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{nome}} - Currículo</title>
  <style>
    * { box-sizing: border-box; color: #1e293b; }
    body { margin: 0; font-family: Arial, Helvetica, sans-serif; background: #f8fafc; color: #1e293b; }
    .cv-article { max-width: 56rem; margin: 2rem auto; background: #ffffff; box-shadow: 0 10px 30px #d1d5db; border-radius: 0.5rem; overflow: hidden; }
    .cv-header { background: #0f172a; background-color: #0f172a; color: #fff; padding: 2.5rem 2rem; }
    .cv-header h1 { font-size: 1.875rem; font-weight: 700; letter-spacing: -0.025em; margin: 0; color: #ffffff; }
    .cv-header .subtitle { color: #cbd5e1; font-size: 1.125rem; margin-top: 0.25rem; }
    .cv-header .links { display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; margin-top: 1.5rem; }
    .cv-header .link-item { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; color: #cbd5e1; text-decoration: none; }
    .cv-header .link-item a { color: #cbd5e1; text-decoration: none; display: flex; align-items: center; gap: 0.375rem; }
    .cv-header .link-item a:hover { color: #fff; }
    .cv-header .link-item svg { flex-shrink: 0; }
    .cv-body { padding: 2rem; }
    .cv-body > * + * { margin-top: 2rem; }
    .cv-section h2 { font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin: 0 0 1rem 0; }
    .cv-section p { color: #334155; line-height: 1.625; margin: 0; }
    .cv-section .space-y-6 > * + * { margin-top: 1.5rem; }
    .cv-section .space-y-4 > * + * { margin-top: 1rem; }
    .cv-section .space-y-3 > * + * { margin-top: 0.75rem; }
    .cv-section .space-y-2 > * + * { margin-top: 0.5rem; }
    .cv-section .space-y-1 > * + * { margin-top: 0.25rem; }
    .cv-job { border-left: 2px solid #e2e8f0; padding-left: 1.25rem; }
    .cv-job .row { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
    .cv-job h3 { font-weight: 600; color: #0f172a; margin: 0; }
    .cv-job .period { font-size: 0.875rem; color: #64748b; }
    .cv-job .company { color: #475569; font-weight: 500; margin-top: 0.25rem; }
    .cv-job .desc { color: #334155; margin-top: 0.5rem; font-size: 0.875rem; }
    .cv-job ul { margin: 0.5rem 0 0 0; padding-left: 1rem; font-size: 0.875rem; color: #334155; list-style: disc inside; }
    .cv-edu h3 { font-weight: 600; color: #0f172a; margin: 0; }
    .cv-edu .meta { color: #475569; font-size: 0.875rem; margin-top: 0.25rem; }
    .cv-skills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .cv-skill { display: inline-block; padding: 0.25rem 0.75rem; background: #f1f5f9; color: #334155; border-radius: 9999px; font-size: 0.875rem; }
    .cv-skill-sm { padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.875rem; }
    .cv-list { color: #334155; list-style: none; padding: 0; margin: 0; }
    .cv-list li { margin-top: 0.25rem; }
    .cv-list li:first-child { margin-top: 0; }
    .cv-link { font-weight: 600; color: #0f172a; text-decoration: none; }
    .cv-link:hover { color: #475569; }
    .cv-cat { font-size: 0.875rem; font-weight: 500; color: #475569; margin-bottom: 0.25rem; }
  </style>
</head>
<body>
  <article class="cv-article">
    <header class="cv-header" style="background-color:#0f172a;color:#fff">
      <h1>{{nome}}</h1>
      {{#if titulo}}
        <p class="subtitle">{{titulo}}</p>
      {{/if}}

      <div class="links">
        {{!-- Email --}}
        <span class="link-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <a href="mailto:{{email}}">{{email}}</a>
        </span>

        {{!-- Telefone --}}
        {{#if telefone}}
        <span class="link-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.09a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17.5z"/>
          </svg>
          <span>{{telefone}}</span>
        </span>
        {{/if}}

        {{!-- Localização --}}
        {{#if localizacao}}
        <span class="link-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <span>{{localizacao}}</span>
        </span>
        {{/if}}

        {{!-- LinkedIn --}}
        {{#if linkedin}}
        <span class="link-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="#94a3b8">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
          </svg>
          <a href="https://{{linkedin}}" target="_blank" rel="noopener">LinkedIn</a>
        </span>
        {{/if}}

        {{!-- GitHub --}}
        {{#if github}}
        <span class="link-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="#94a3b8">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
          <a href="https://{{github}}" target="_blank" rel="noopener">GitHub</a>
        </span>
        {{/if}}

        {{!-- Instagram --}}
        {{#if instagram}}
        <span class="link-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
          <a href="https://{{instagram}}" target="_blank" rel="noopener">Instagram</a>
        </span>
        {{/if}}

        {{!-- Website --}}
        {{#if website}}
        <span class="link-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 1 0 20 14.5 14.5 0 0 1 0-20"/><path d="M2 12h20"/>
          </svg>
          <a href="{{website}}" target="_blank" rel="noopener">Website</a>
        </span>
        {{/if}}
      </div>
    </header>

    <div class="cv-body">
      {{#if resumo}}
        <section class="cv-section">
          <h2>Resumo</h2>
          <p>{{resumo}}</p>
        </section>
      {{/if}}

      {{#if experiencias}}
        <section class="cv-section">
          <h2>Experiência profissional</h2>
          <div class="space-y-6">
            {{#each experiencias}}
              <div class="cv-job">
                <div class="row">
                  <h3>{{cargo}}</h3>
                  <span class="period">{{periodo}}</span>
                </div>
                <p class="company">{{empresa}}{{#if local}} · {{local}}{{/if}}</p>
                {{#if descricao}}
                  <p class="desc">{{descricao}}</p>
                {{/if}}
                {{#if conquistas}}
                  <ul>
                    {{#each conquistas}}
                      <li>{{this}}</li>
                    {{/each}}
                  </ul>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if formacao}}
        <section class="cv-section">
          <h2>Formação</h2>
          <div class="space-y-4">
            {{#each formacao}}
              <div class="cv-edu">
                <h3>{{curso}}</h3>
                <p class="meta">{{instituicao}} · {{periodo}}</p>
                {{#if descricao}}<p class="desc">{{descricao}}</p>{{/if}}
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if habilidadesLista}}
        <section class="cv-section">
          <h2>Habilidades</h2>
          <div class="cv-skills">
            {{#each habilidadesLista}}
              <span class="cv-skill">{{this}}</span>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if habilidadesCategorias}}
        <section class="cv-section">
          <h2>Habilidades</h2>
          <div class="space-y-3">
            {{#each habilidadesCategorias}}
              <div>
                <p class="cv-cat">{{categoria}}</p>
                <div class="cv-skills">
                  {{#each itens}}
                    <span class="cv-skill cv-skill-sm">{{this}}</span>
                  {{/each}}
                </div>
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if idiomas}}
        <section class="cv-section">
          <h2>Idiomas</h2>
          <ul class="cv-list">
            {{#each idiomas}}
              <li><span style="font-weight:600">{{idioma}}</span> — {{nivel}}</li>
            {{/each}}
          </ul>
        </section>
      {{/if}}

      {{#if projetos}}
        <section class="cv-section">
          <h2>Projetos</h2>
          <div class="space-y-4">
            {{#each projetos}}
              <div>
                {{#if link}}
                  <a href="{{link}}" target="_blank" rel="noopener" class="cv-link">{{nome}}</a>
                {{else}}
                  <h3 style="font-weight:600;color:#0f172a;margin:0">{{nome}}</h3>
                {{/if}}
                {{#if descricao}}<p class="desc">{{descricao}}</p>{{/if}}
                {{#if tecnologias}}
                  <div class="cv-skills" style="margin-top:0.5rem">
                    {{#each tecnologias}}
                      <span class="cv-skill cv-skill-sm">{{this}}</span>
                    {{/each}}
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if certificacoes}}
        <section class="cv-section">
          <h2>Certificações</h2>
          <ul class="cv-list" style="margin-top:0.5rem">
            {{#each certificacoes}}
              <li>
                {{#if link}}<a href="{{link}}" target="_blank" rel="noopener" style="text-decoration:underline">{{nome}}</a>{{else}}{{nome}}{{/if}}
                {{#if emissor}} · {{emissor}}{{/if}}{{#if ano}} ({{ano}}){{/if}}
              </li>
            {{/each}}
          </ul>
        </section>
      {{/if}}
    </div>
  </article>
</body>
</html>
